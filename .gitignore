# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# Pipeline runtime artifacts
extracted/
output/
renders/
logs/

# Downloaded archives (collect_aminet.py output) — keep README only
archives_raw/*
!archives_raw/README.txt

# Generated reference variants (regenerate via trim_reference.py /
# build_reference_variants.py). The originals (ojisan.png and the kudan
# captures) are tracked; everything derived from them is not.
references/*_trimmed.*
references/ojisan/ojisan_trimmed.*
references/ojisan/ojisan_all*.png
references/ojisan/ojisan_binary*.png
references/ojisan/ojisan_edges*.png
references/ojisan/ojisan_face*.png
references/ojisan/ojisan_grayscale*.png
references/ojisan/ojisan_hair*.png
references/ojisan/ojisan_head*.png
references/ojisan/ojisan_silhouette*.png
references/ojisan/ojisan_torso*.png

# External binary tools (download/extract locally, never commit).
# JRE alone is ~50 MB; jpsxdec ships its own bundle of jars/exes.
tools/jre/
tools/jpsxdec/
tools/*.zip
tools/*.tar.*

# jpsxdec runtime / debug output (auto-generated each run)
debug*.log
索引.log
*.idx

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# Claude Code session metadata (scheduled_tasks.lock etc.)
.claude/
